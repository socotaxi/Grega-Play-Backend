# ==== SUPABASE ====
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==== SECURITY ====
API_SECRET=change-me-in-production


# ==== EMAIL (SMTP Brevo — prioritaire) ====
# Créer un compte sur brevo.com → SMTP & API → SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@email.com
SMTP_PASSWORD=your-brevo-smtp-key
SMTP_FROM_EMAIL=no-reply@gregaplay.com
SMTP_FROM_NAME=Grega Play

# ==== EMAIL (SendGrid — fallback si SMTP non configuré) ====
SENDGRID_API_KEY=your-sendgrid-key-here

# ==== PUSH NOTIFICATIONS ====
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@gregaplay.com

VITE_API_BASE_URL=https://ton-backend-gregaplay.up.railway.app

