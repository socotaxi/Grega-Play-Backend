# ==== SUPABASE ====
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==== SECURITY ====
# Clé secrète partagée avec le frontend (header x-api-key)
INTERNAL_API_KEY=change-me-in-production

# ==== ADMIN ====
ADMIN_EMAIL=your-admin-email@example.com

# ==== CORS ====
# Origines autorisées (séparées par virgule). Laisser vide = tout autoriser (dev seulement)
CORS_ORIGINS=https://your-frontend.vercel.app

# ==== URLS ====
PUBLIC_SITE_URL=https://your-frontend.vercel.app

# ==== EMAIL — choisir SMTP ou SendGrid ====
# Option 1 : SMTP (ex. Brevo / Hostinger)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@gregaplay.com
SMTP_FROM_NAME=Grega Play

# Option 2 : SendGrid
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@gregaplay.com
SENDGRID_FROM_NAME=Grega Play

# ==== PUSH NOTIFICATIONS ====
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@gregaplay.com

# ==== STRIPE (désactivé — PAYMENTS_ENABLED = false) ====
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ==== FFMPEG (optionnel — valeurs par défaut indiquées) ====
# FFMPEG_TIMEOUT_MS=1200000     # 20 min
# FFMPEG_INACTIVITY_MS=90000    # 90 s
# FFMPEG_THREADS=0              # 0 = auto
# NORMALIZE_PRESET=ultrafast
# MAX_CLIP_SEC=35
